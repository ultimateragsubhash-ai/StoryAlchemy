# Railway Deployment Environment Variables
# Copy these values to your Railway dashboard

# LLM API (Required)
MESHAPI_API_KEY=your_meshapi_key_here
MESHAPI_BASE_URL=https://api.meshapi.ai/v1

# MongoDB Atlas (Required - use MongoDB Atlas for production)
# Get connection string from: https://cloud.mongodb.com
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/storyalchemy?retryWrites=true&w=majority

# Redis Cloud (Required - use Redis Cloud for production)
# Get from: https://redis.io/cloud/
REDIS_URL=redis://default:password@host.redis-cloud.com:port

# Qdrant Cloud (Required - use Qdrant Cloud for production)
# Get from: https://cloud.qdrant.io
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION=story_patterns

# Application Settings
ENV=production
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=https://your-app.streamlit.app

# Feature Flags
ENABLE_SEMANTIC_CACHE=true
MAX_ITERATIONS=1
CACHE_TTL_SECONDS=604800
MAX_REQUESTS_PER_HOUR=100

# Models
DEFAULT_EMBEDDING_MODEL=all-MiniLM-L6-v2
DEFAULT_GENERATION_MODEL=openai/gpt-4o-mini
CHEAP_MODEL=openai/gpt-4o-mini
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
