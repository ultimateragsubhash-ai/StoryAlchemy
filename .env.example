# LLM API (MeshAPI or OpenAI-compatible)
MESHAPI_API_KEY=
MESHAPI_BASE_URL=https://api.meshapi.ai/v1

# Alternative: Direct OpenAI
OPENAI_API_KEY=your_openai_key_here

# Vector Database (Qdrant Local)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=story_patterns

# Redis (for caching)
REDIS_URL=redis://localhost:6379/0

# MongoDB (for persistence)
# For Docker (with auth from docker-compose.yml):
MONGODB_URL=mongodb://admin:password123@localhost:27017/storyalchemy?authSource=admin
# For local MongoDB without auth:
# MONGODB_URL=mongodb://localhost:27017/storyalchemy

# Application Settings
ENV=development
PORT=8000
LOG_LEVEL=INFO

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# Feature Flags
ENABLE_SEMANTIC_CACHE=true
MAX_ITERATIONS=1
CACHE_TTL_SECONDS=604800
MAX_REQUESTS_PER_HOUR=100

# Models (MeshAPI/OpenRouter format: provider/model)
DEFAULT_EMBEDDING_MODEL=all-MiniLM-L6-v2
DEFAULT_GENERATION_MODEL=openai/gpt-4o-mini
CHEAP_MODEL=openai/gpt-4o-mini
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
